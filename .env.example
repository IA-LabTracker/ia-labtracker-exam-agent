DATABASE_URL=postgresql://postgres:postgres@localhost:5432/exam_reconciler

EMBEDDINGS_PROVIDER=local
OPENAI_API_KEY=
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

HYBRID_ALPHA=0.7
HYBRID_BETA=0.3
SIMILARITY_THRESHOLD=0.4
RETRIEVER_TOP_K=5

# LLM Judge (optional - validates low-confidence matches via AI)
LLM_JUDGE_ENABLED=false
LLM_JUDGE_MODEL=gpt-4o-mini
LLM_JUDGE_BASE_URL=
LLM_JUDGE_THRESHOLD=0.60

LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
